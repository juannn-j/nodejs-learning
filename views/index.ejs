<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title><%= title %></title>
    <%= title %>
    <% if(showMessage) { %>
        <p><%= message %></p>
    <% } else { %>
        <p>Este es un mensaje por defecto</p>
    <% } %>
    <ul>
        <% for (let i = 0; i < items.length; i++) { %>
            <li><%= items[i] %></li>
        <% } %>
    </ul>
</head>
<body>
    
</body>
</html>


